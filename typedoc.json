{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/hooks",
    "src/lib",
    "src/services",
    "src/types"
  ],
  "entryPointStrategy": "expand",
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "**/node_modules/**"
  ],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "name": "MasterQuiz API Reference",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "skipErrorChecking": true,
  "githubPages": false,
  "hideGenerator": true
}
